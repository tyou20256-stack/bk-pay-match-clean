{
  "name": "bk-p2p-aggregator",
  "version": "1.0.0",
  "description": "P2P Exchange Rate Aggregator Dashboard",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "npx tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/api.test.ts tests/api-security.test.ts tests/extended.test.ts tests/integration.test.ts tests/phase3-5.test.ts",
    "test:all": "vitest run --config vitest.all.config.ts",
    "test:watch": "vitest",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "backup": "bash scripts/backup.sh",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop bk-pay-match",
    "pm2:logs": "pm2 logs bk-pay-match",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "axios": "^1.7.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.0.0",
    "ccxt": "^4.5.40",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "otplib": "^13.3.0",
    "puppeteer": "^24.37.5",
    "qrcode": "^1.5.4",
    "tronweb": "^6.2.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
